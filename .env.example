# Mini Researcher Agent - PocketFlow Edition Configuration
# Copy this file to .env and fill in your actual values

# ============================================================================
# OpenRouter API (Required)
# ============================================================================
# Get your API key from: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...

# Model to use (default: anthropic/claude-3.5-sonnet)
# See available models: https://openrouter.ai/models
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet

# ============================================================================
# Experimentation Mode
# ============================================================================
# Enable Docker for isolated experiments (recommended for reproducibility)
# Set to False for faster local execution (good for development)
ENABLE_DOCKER=False

# Docker image to use when ENABLE_DOCKER=True
DOCKER_IMAGE=python:3.13

# Experiment execution timeout (seconds)
DOCKER_TIMEOUT=3600

# ============================================================================
# Budget Control (Optional Overrides)
# ============================================================================
# These override the automatic classification if set
# Leave commented to use automatic complexity-based allocation

# MAX_ROUNDS_LOW=20
# MAX_ROUNDS_MEDIUM=120
# MAX_ROUNDS_HIGH=250
