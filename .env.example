# ── Required ─────────────────────────────────────────────────────────────────
# Core LLM inference — every node calls the LLM through this key
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# Required by: tooluniverse (model/dataset discovery on HF Hub)
HF_TOKEN=hf_your-token-here

# Required by: github-mining (code/repo search via GitHub GraphQL API)
GITHUB_TOKEN=ghp_your-token-here

# Required by: paper-2-web (HTML/video/poster export)
OPENAI_API_KEY=sk-proj-your-key-here

# ── Inference config ──────────────────────────────────────────────────────────
# Base URL for the OpenAI-compatible API endpoint
INFERENCE_BASE_URL=https://openrouter.ai/api/v1

# Model identifier (as accepted by the endpoint above)
MODEL_NAME=z-ai/glm-5

# Pricing (dollars per 1 million tokens) — set manually from provider pricing page
INPUT_TOKEN_COST_PER_MILLION=0.95
OUTPUT_TOKEN_COST_PER_MILLION=2.55

# ── Agent tuning ──────────────────────────────────────────────────────────────
# How many recent history entries ResearchExecutor shows the LLM (default: 3)
LOOKBACK=3

# How many review cycles ReviewExecutor will run before forcing compile (default: 1)
MAX_REVIEW_ROUNDS=1
